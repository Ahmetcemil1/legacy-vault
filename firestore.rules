rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      // Authenticated users can read other profile documents to verify beneficiary registrations
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      
      // Trusted contacts subcollection
      match /trusted_contacts/{contactId} {
        allow read: if request.auth != null && (request.auth.uid == userId || request.auth.uid == contactId);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if request.auth != null && (
          request.auth.uid == userId || 
          (request.auth.uid == contactId && 
           get(/databases/$(database)/documents/users/$(userId)).data.releaseStatus == 'pending_release' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvedRelease']))
        );
        allow delete: if request.auth != null && request.auth.uid == userId;
      }
      
      // Vault items subcollection
      match /vault_items/{itemId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          (get(/databases/$(database)/documents/users/$(userId)).data.switchTriggered == true &&
           exists(/databases/$(database)/documents/users/$(userId)/trusted_contacts/$(request.auth.uid)))
        );
        allow write: if request.auth != null && request.auth.uid == userId;
      }
      
      // Video messages subcollection
      match /video_messages/{videoId} {
        allow read: if request.auth != null && (
          request.auth.uid == userId ||
          (get(/databases/$(database)/documents/users/$(userId)).data.switchTriggered == true &&
           exists(/databases/$(database)/documents/users/$(userId)/trusted_contacts/$(request.auth.uid)))
        );
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Death Claims collection - anyone can submit/create a claim, but only admin can view/read/update
    match /claims/{claimId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
